# ============================================================
# Health Watchers Environment Configuration
# ============================================================
# This file documents all required environment variables.
# Create a .env file locally by copying this and filling in values.
# NEVER commit .env to git - it's in .gitignore
#
# HIPAA Security Notice:
# - All secrets are sensitive and require proper handling
# - Use AWS Secrets Manager or HashiCorp Vault in production
# - Rotate secrets according to the schedule in SECURITY.md
# - See SECURITY.md for comprehensive secrets management guide
# ============================================================

# ============================================================
# API Server Configuration
# ============================================================

# HTTP port for Express API server
# Default: 3001 (production) / 4000 (development)
# Production: Use port 3001
API_PORT=3001

# Node environment: development | staging | production
# Affects logging, error handling, and security settings
NODE_ENV=development

# ============================================================
# Database Configuration (CRITICAL SECRET - ROTATE QUARTERLY)
# ============================================================

# MongoDB connection URI with authentication
# Format: mongodb://username:password@host:port/database?authSource=admin
# 
# Local Development:
#   mongodb://localhost:27017/health_watchers
#
# Docker Compose:
#   mongodb://admin:password123@mongodb:27017/health_watchers?authSource=admin
#
# Production (AWS DocumentDB or MongoDB Atlas):
#   mongodb+srv://user:password@cluster.mongodb.net/health_watchers?ssl=true
#
# SECURITY: This contains credentials. Manage in Secrets Manager only.
# ROTATION: Quarterly - requires MongoDB user update
# AUDIT: All database connections are logged
MONGO_URI=mongodb://localhost:27017/health_watchers

# ============================================================
# JWT Authentication Secrets (CRITICAL - ROTATE MONTHLY)
# ============================================================

# Access token secret - signs short-lived JWT tokens (15m expiration)
# Used by token.service.ts to sign and verify access tokens
# Each user request uses this to authenticate
#
# Generate secure secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# SECURITY: Must be cryptographically random, 64+ bytes
# ROTATION: Monthly with 30-day grace period
# IMPACT: All active access tokens become invalid after rotation
# STORAGE: AWS Secrets Manager - health-watchers/prod/api
JWT_ACCESS_TOKEN_SECRET=dev-access-token-secret-change-in-production

# Refresh token secret - signs longer-lived JWT tokens (7d expiration)
# Used to issue new access tokens without re-authentication
# Stored in secure HTTP-only cookies
#
# Generate secure secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# SECURITY: Must be cryptographically random, 64+ bytes
# SECURITY: Different from access token secret (defense in depth)
# ROTATION: Monthly with 30-day grace period
# IMPACT: Users need to re-login after rotation
# STORAGE: AWS Secrets Manager - health-watchers/prod/api
JWT_REFRESH_TOKEN_SECRET=dev-refresh-token-secret-change-in-production

# ============================================================
# Stellar Blockchain Configuration (HIGH-RISK - ROTATE QUARTERLY)
# ============================================================

# Stellar network: testnet | mainnet
# testnet - For development/testing with fake XLM
# mainnet - For production with real value
# 
# SECURITY: Easy to confuse - double-check before production deployment
# WARNING: Mainnet transactions involve real money
STELLAR_NETWORK=testnet

# Stellar secret key for blockchain transactions
# This is a PRIVATE KEY - treat with extreme care
# Format: Ed25519 private key starting with 'S'
# 
# Generate new keypair:
#   const sdk = require('@stellar/stellar-sdk');
#   const kp = sdk.Keypair.random();
#   public: kp.publicKey()
#   secret: kp.secret()
#
# SECURITY: This key can sign transactions and move funds
# SECURITY: Compromise = loss of funds
# IMPACT: Affects blockchain transaction processing
# ROTATION: Quarterly - requires account funding transfer
# STORAGE: AWS Secrets Manager - health-watchers/prod/stellar
# ENCRYPT: Always encrypted at rest and in transit
STELLAR_SECRET_KEY=your-stellar-secret-key-testnet-only

# Stellar public key (optional, derived from secret key)
# Used for informational purposes and fund requests
# Not sensitive - can be shared publicly
STELLAR_PUBLIC_KEY=your-stellar-public-key

# ============================================================
# AI/LLM Configuration (MEDIUM-RISK - ROTATE QUARTERLY)
# ============================================================

# Google Gemini API Key for health AI analysis
# Used for AI-powered health insights and recommendations
# 
# Obtain key:
#   1. Go to Google Cloud Console
#   2. Create/select a project
#   3. Enable Gemini API
#   4. Create API key in Credentials
#   5. Set restrictions: HTTP referrers, IP addresses
#
# SECURITY: Limit API key usage via API restrictions
# SECURITY: Set IP whitelists if possible
# IMPACT: Affects AI feature availability
# ROTATION: Quarterly when rotating API keys
# STORAGE: AWS Secrets Manager - health-watchers/prod/external
# COST: Each API call is billable - monitor usage
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================
# Application Behavior Configuration
# ============================================================

# Next.js telemetry - disable for privacy
# true = send usage data to Vercel
# false = no data collection (recommended for production)
NEXT_TELEMETRY_DISABLED=1

# Next.js public API URL - accessible from browser
# Used to construct API calls from the frontend
# Format: https://api.example.com or http://localhost:3001
# In Docker: http://api:3001 (service discovery)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================================
# Logging Configuration
# ============================================================

# Log level: error | warn | info | debug | trace
# error - Only critical errors
# warn - Warnings and errors
# info - Normal application flow (default)
# debug - Detailed debugging information (dev only)
# trace - Very verbose (dev only)
LOG_LEVEL=info

# ============================================================
# AWS Configuration (if using AWS Secrets Manager)
# ============================================================

# AWS region for Secrets Manager
# Example: us-east-1, eu-west-1
# Required: Only if ENABLE_SECRETS_MANAGER=true
AWS_REGION=us-east-1

# Enable AWS Secrets Manager for secret retrieval
# true = fetch secrets from AWS Secrets Manager
# false = use environment variables (.env files)
# Default: false (development), true (production)
ENABLE_SECRETS_MANAGER=false

# ============================================================
# Monitoring & Observability
# ============================================================

# Sentry DSN for error tracking
# Leave empty to disable
# Format: https://key@sentry.io/project-id
SENTRY_DSN=

# Additional environment identifier
# Used in logs and monitoring to identify deployment
ENV_NAME=development

# ============================================================
# IMPORTANT SECURITY REMINDERS
# ============================================================
#
# DO NOT COMMIT THIS FILE WITH REAL SECRETS:
# ✗ Add real .env to .gitignore (already done)
# ✗ Use this .env.example for documentation only
# ✗ Never paste real credentials here
#
# MANAGING SECRETS PROPERLY:
# ✓ Development: Use .env and .gitignore locally
# ✓ Staging: Use AWS Secrets Manager or Vault
# ✓ Production: Use AWS Secrets Manager with IAM policies
# ✓ CI/CD: Use GitHub Secrets or CI platform secrets
#
# ROTATION SCHEDULE:
# Monthly: JWT_ACCESS_TOKEN_SECRET, JWT_REFRESH_TOKEN_SECRET
# Quarterly: MONGO_URI, STELLAR_SECRET_KEY, GEMINI_API_KEY
#
# AUDIT & COMPLIANCE:
# - All secret access is logged (HIPAA requirement)
# - Secrets Manager provides audit trail (CloudTrail)
# - Pre-commit hooks prevent accidental commits
# - CI/CD scans for hardcoded secrets
#
# Setup Instructions:
# 1. Copy .env.example to .env
# 2. Fill in values for your environment
# 3. Run: bash scripts/setup-hooks.sh (to enable pre-commit checks)
# 4. Review: SECURITY.md for complete secrets management guide
#
# ============================================================
