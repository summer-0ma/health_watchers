{
  "name": "api",
  "version": "1.0.0",
  "scripts": {
    "dev":   "ts-node-dev --respawn src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "lint":  "eslint src",
    "test":  "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage"
  },
  "dependencies": {
    "express":    "^4.18.2",
    "mongoose":   "^8.0.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs":   "^2.4.3",
    "dotenv":     "^16.0.0",
    "@health-watchers/config": "*",
    "@health-watchers/types":  "*",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs":      "^2.4.6",
    "@types/express":       "^4.17.21",
    "@types/jest":          "^29.5.12",
    "@types/jsonwebtoken":  "^9.0.0",
    "@types/supertest":     "^6.0.2",
    "jest":                 "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "supertest":            "^7.0.0",
    "ts-jest":              "^29.1.4",
    "ts-node-dev":          "^2.0.0",
    "typescript":           "latest"
  }
