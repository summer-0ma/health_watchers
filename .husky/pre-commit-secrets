#!/bin/sh
# Scan staged files for common secret patterns before committing

staged_files=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$staged_files" ]; then
  exit 0
fi

found=0
for file in $staged_files; do
  case "$file" in
    *.lock|package-lock.json|*.png|*.jpg|*.gif|*.ico|*.woff*) continue ;;
  esac

  if git diff --cached -- "$file" | grep -qE \
    "AKIA[0-9A-Z]{16}|-----BEGIN (RSA|EC|DSA|OPENSSH) PRIVATE KEY-----|ghp_[0-9a-zA-Z]{36}|sk-[a-zA-Z0-9]{48}|xox[baprs]-[0-9a-zA-Z]{10,}|password\s*=\s*['\"][^'\"]{8,}['\"]|secret\s*=\s*['\"][^'\"]{8,}['\"]|api[_-]?key\s*=\s*['\"][^'\"]{8,}['\"]"; then
    echo "❌ Potential secret detected in: $file"
    found=1
  fi
done

if [ "$found" -eq 1 ]; then
  echo ""
  echo "Commit blocked. Remove secrets before committing."
  echo "If this is a false positive, use: git commit --no-verify"
  exit 1
fi
